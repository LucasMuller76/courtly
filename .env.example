# Banco de dados
# Local:    postgresql://postgres:senha@localhost:5432/courtly
# Supabase: postgresql://postgres:[senha]@db.[projeto].supabase.co:5432/postgres
# Railway:  (cole a URL que o Railway gera automaticamente)
DATABASE_URL=postgresql://postgres:senha@localhost:5432/courtly

# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria

# development | production
ENVIRONMENT=development

# WhatsApp
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Email via Resend (resend.com — plano gratuito: 3.000 emails/mês)
RESEND_API_KEY=