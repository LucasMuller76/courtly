# postgresql://usuario:senha@host:porta/banco
# Local:    postgresql://postgres:senha@localhost:5432/courtly
# Supabase: postgresql://postgres:[senha]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:senha@localhost:5432/courtly

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-aqui

ENVIRONMENT=development

# Origins permitidas (Next.js em dev e produção)
ALLOWED_ORIGINS=["http://localhost:3000"]

# WhatsApp (configurar depois)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Resend — email gratuito até 3.000/mês (resend.com)
RESEND_API_KEY=